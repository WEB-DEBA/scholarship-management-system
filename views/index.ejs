<!DOCTYPE html>
<html>
<head>
  <title>PNS Scholarship</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<header class="new-header">
  <div class="new-logo">
    <span>🎓</span>
    <b>PNS Scholarship</b>
  </div>

  <input type="checkbox" id="menuToggle">
  <label for="menuToggle" class="hamburger">☰</label>

  <nav class="new-nav">
    <a href="/">Home</a>
    <a href="/apply">Apply</a>
    <a href="/check">Check Status</a>
    <a href="/notice">Notice</a>
    <a href="/login" class="admin-pill">Admin Login</a>
  </nav>
</header>

<section class="new-hero">
  <div class="new-hero-left">
    <p class="new-tag">SC/ST Digital Scholarship Portal</p>

    <h1>Empowering Students,<br>Building a Better Future</h1>

    <p class="new-hero-text">
      Apply online, verify registration number, track scholarship status
      and manage student records easily.
    </p>

    <div class="new-hero-buttons">
      <a href="/apply" class="primary-btn">Apply Now →</a>
      <a href="/check" class="outline-btn">Check Status →</a>
    </div>
  </div>

  <div class="new-hero-right">
    <div class="book-card">
      <div class="cap">🎓</div>
      <div class="books">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </div>
</section>

<section class="new-stats">
  <div>
    <span>🎓</span>
    <h2>500+</h2>
    <p>Registered Students</p>
  </div>

  <div>
    <span>📄</span>
    <h2>100%</h2>
    <p>Digital Process</p>
  </div>

  <div>
    <span>🔄</span>
    <h2>24/7</h2>
    <p>Status Tracking</p>
  </div>

  <div>
    <span>🛡️</span>
    <h2>Secure</h2>
    <p>Data Protection</p>
  </div>
</section>

<section class="new-section">
  <p class="section-small">OUR FEATURES</p>
  <h2>Premium Portal Features</h2>

  <div class="new-feature-grid">
    <div class="new-feature-card">
      <span>📋</span>
      <h3>Scholarship Apply</h3>
      <p>Students can submit complete scholarship details online.</p>
    </div>

    <div class="new-feature-card">
      <span>🔍</span>
      <h3>Status Check</h3>
      <p>Track application status using registration number.</p>
    </div>

    <div class="new-feature-card">
      <span>📢</span>
      <h3>Dynamic Notices</h3>
      <p>Admin can publish important scholarship notices anytime.</p>
    </div>

    <div class="new-feature-card">
      <span>👨‍💼</span>
      <h3>Admin Dashboard</h3>
      <p>Verify, approve, reject and manage applications.</p>
    </div>
  </div>
</section>

<section class="new-notice-section">
  <div class="notice-head">
    <h2>Latest Scholarship Notices</h2>
    <a href="/notice">View All Notices</a>
  </div>

  <div class="new-notice-list">
    <% if(notices && notices.length > 0){ %>
      <% notices.slice(0,3).forEach(n => { %>
        <div class="new-notice-card">
          <div>
            <span class="notice-chip"><%= n.category || "Scholarship" %></span>
            <span class="priority-chip"><%= n.priority || "High" %></span>
          </div>

          <h3><%= n.title %></h3>
          <p><%= n.message %></p>
          <small>📅 <%= n.date %></small>
        </div>
      <% }) %>
    <% } else { %>
      <div class="new-notice-card">
        <span class="notice-chip">Scholarship</span>
        <span class="priority-chip">High</span>
        <h3>No Notice Available</h3>
        <p>Latest scholarship notice will appear here.</p>
      </div>
    <% } %>
  </div>
</section>

<footer class="new-footer">
  <div class="footer-grid">
    <div>
      <h3>PNS Scholarship</h3>
      <p>Smart, secure and transparent scholarship management system.</p>
    </div>

    <div>
      <h4>Contact Us</h4>
      <p>📞 +91 79786 09045</p>
      <p>✉ support@pnsscholarship.in</p>
    </div>

    <div>
      <h4>Quick Links</h4>
      <a href="/">Home</a>
      <a href="/apply">Apply</a>
      <a href="/check">Check Status</a>
    </div>

    <div>
      <h4>Important Links</h4>
      <a href="/notice">Notice</a>
      <a href="/login">Admin Login</a>
    </div>
  </div>

  <p class="copyright">© 2026 PNS Scholarship Portal. All Rights Reserved.</p>
</footer>

<a href="https://wa.me/917978609045" class="floating-wa">💬</a>

</body>
</html>