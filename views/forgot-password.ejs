<!DOCTYPE html>
<html>
<head>
  <title>Forgot Password - PNS Scholarship Portal</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<section class="login-page">

  <div class="login-shape shape1"></div>
  <div class="login-shape shape2"></div>

  <div class="login-container">

    <div class="login-left">
      <p class="login-tag">Password Recovery</p>

      <h1>
        Reset <br>
        Admin Password
      </h1>

      <p>
        Secure OTP verification system. Enter your registered email or phone number and receive an OTP instantly.
      </p>

      <div class="login-features">

        <div class="login-feature">
          <span>🔐</span>
          <div>
            <h3>Secure OTP</h3>
            <p>Password reset through email verification.</p>
          </div>
        </div>

        <div class="login-feature">
          <span>⚡</span>
          <div>
            <h3>Fast Recovery</h3>
            <p>Get OTP instantly and recover access quickly.</p>
          </div>
        </div>

        <div class="login-feature">
          <span>🛡️</span>
          <div>
            <h3>Protected Access</h3>
            <p>Only registered admin accounts can reset passwords.</p>
          </div>
        </div>

      </div>
    </div>

    <div class="login-right">

      <form action="/forgot-password" method="POST" class="premium-login-box">

        <div class="login-top">
          <div class="login-icon">🔑</div>
          <h2>Forgot Password</h2>
          <p>Receive OTP on your registered email</p>
        </div>

        <% if (error) { %>
          <div class="error-box">
            <%= error %>
          </div>
        <% } %>

        <div class="input-box">
          <label>Email or Phone Number</label>
          <input
            type="text"
            name="email"
            placeholder="Enter registered email or phone"
            required
          >
        </div>

        <button type="submit" class="login-btn">
          Send OTP
        </button>

        <a href="/login" class="back-home">
          ← Back to Login
        </a>

      </form>

    </div>

  </div>

</section>

</body>
</html>