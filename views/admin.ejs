<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<%- include("partials/header") %>

<section class="admin-dashboard">

  <div class="admin-hero">
    <div>
      <p class="admin-tag">Scholarship Control Panel</p>
      <h1>Admin Dashboard</h1>
      <p>Manage applications, documents, payments and scholarship status.</p>
    </div>

    <div class="admin-actions">
      <a href="/admin/application-details" class="logout-btn">Application Details</a>
      <a href="/admin/payments" class="logout-btn">Payment Records</a>
      <a href="/admin/logs" class="logout-btn">Audit Logs</a>
      <a href="/logout" class="logout-btn">Logout</a>
    </div>
  </div>

  <div class="admin-stats">
    <div class="admin-stat-card">
      <span>🎓</span>
      <p>Total Applications</p>
      <h2><%= students.length %></h2>
    </div>

    <div class="admin-stat-card success-card">
      <span>✅</span>
      <p>Success</p>
      <h2><%= students.filter(s => s.status === "Success").length %></h2>
    </div>

    <div class="admin-stat-card pending-card">
      <span>⏳</span>
      <p>Pending</p>
      <h2><%= students.filter(s => s.status === "Pending").length %></h2>
    </div>

    <div class="admin-stat-card failed-card">
      <span>❌</span>
      <p>Failed</p>
      <h2><%= students.filter(s => s.status === "Failed").length %></h2>
    </div>
  </div>

  <div class="admin-panel-grid">

    <div class="admin-box">
      <div class="box-heading">
        <span>📢</span>
        <div>
          <h2>Add Notice</h2>
          <p>Create latest scholarship updates.</p>
        </div>
      </div>

      <form action="/admin/notice" method="POST" class="notice-form">
        <input type="text" name="title" placeholder="Notice Title" required>
        <input type="text" name="message" placeholder="Notice Message" required>
        <button>Add Notice</button>
      </form>
    </div>

    <div class="admin-box">
      <div class="box-heading">
        <span>💬</span>
        <div>
          <h2>WhatsApp Direct</h2>
          <p>Send direct WhatsApp message to any number.</p>
        </div>
      </div>

      <form action="/admin/direct-whatsapp" method="POST" class="notice-form">
        <input type="text" name="phone" placeholder="Enter Mobile Number" required>
        <textarea name="message" placeholder="Write WhatsApp message" required></textarea>
        <button>Send WhatsApp</button>
      </form>
    </div>

  </div>

  <div class="admin-box full-box">

    <div class="box-heading">
      <span>📋</span>
      <div>
        <h2>Student Applications</h2>
        
      </div>
    </div>

 

    <div class="table-wrap">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Select</th>
            <th>Student</th>
            <th>Aadhaar</th>
            <th>Phone</th>
            <th>Course</th>
            <th>College</th>
            <th>Profile</th>
            <th>Documents</th>
            <th>Update</th>
            <th>Save Application</th>
            <th>Delete</th>
          </tr>
        </thead>

        <tbody>
          <% if (students.length === 0) { %>
            <tr>
              <td colspan="11" style="text-align:center;">No new applications found</td>
            </tr>
          <% } %>

          <% students.forEach(s => { %>

            <tr
              class="student-row"
              data-name="<%= (s.name || '').toLowerCase() %>"
              data-aadhaar="<%= (s.aadhaar || '').toLowerCase() %>"
              data-registration="<%= (s.registrationNo || '').toLowerCase() %>"
            >

              <td>
                <input form="studentActionForm" type="checkbox" name="phones" value="<%= s.phone %>">
              </td>

              <td>
                <b><%= s.name || "N/A" %></b><br>
                <small><%= s.registrationNo || "Reg No N/A" %></small><br>

                <a
                  href="https://wa.me/91<%= s.phone %>?text=Hello%20<%= s.name %>,%20your%20scholarship%20application%20status%20is%20<%= s.status %>"
                  target="_blank"
                  class="wa-direct-btn"
                >
                  WhatsApp
                </a>
              </td>

              <td><%= s.aadhaar || "N/A" %></td>
              <td><%= s.phone || "N/A" %></td>

              <td>
                <%= s.course || "N/A" %><br>
                <small><%= s.branch || "N/A" %> / <%= s.semester || "N/A" %></small>
              </td>

              <td><%= s.college || "N/A" %></td>

              <td>
                <a href="/admin/student/<%= s._id %>" class="view-btn">Full Profile</a>

                <button type="button" class="view-btn" onclick="toggleDetails('<%= s._id %>')">
                  Quick View
                </button>
              </td>

              <td>
                <div class="doc-mini-links">
                  <% if (s.aadhaarFile) { %><a href="/uploads/<%= s.aadhaarFile %>" target="_blank">Aadhaar</a><% } %>
                  <% if (s.casteFile) { %><a href="/uploads/<%= s.casteFile %>" target="_blank">Caste</a><% } %>
                  <% if (s.incomeFile) { %><a href="/uploads/<%= s.incomeFile %>" target="_blank">Income</a><% } %>
                  <% if (s.photoFile) { %><a href="/uploads/<%= s.photoFile %>" target="_blank">Photo</a><% } %>
                  <% if (s.bankFile) { %><a href="/uploads/<%= s.bankFile %>" target="_blank">Bank</a><% } %>
                  <% if (s.marksheetFile) { %><a href="/uploads/<%= s.marksheetFile %>" target="_blank">Marksheet</a><% } %>
                </div>
              </td>

              <td>
                <form action="/admin/status/<%= s._id %>" method="POST" class="status-mini-form">
                  <select name="status">
                    <option <%= s.status === "Pending" ? "selected" : "" %>>Pending</option>
                    <option <%= s.status === "Success" ? "selected" : "" %>>Success</option>
                    <option <%= s.status === "Failed" ? "selected" : "" %>>Failed</option>
                  </select>
                  <button>Save</button>
                </form>
              </td>

              <td>
                <form action="/admin/application/save/<%= s._id %>" method="POST">
                  <button class="btn-success">Save Application</button>
                </form>
              </td>

              <td>
                <form action="/admin/delete/<%= s._id %>" method="POST">
                  <button class="danger">Delete</button>
                </form>
              </td>

            </tr>

            <tr id="details-<%= s._id %>" class="student-detail-row">
              <td colspan="11">
                <div class="student-full-box">
                  <h3>Student Full Details</h3>

                  <p><b>Name:</b> <%= s.name || "N/A" %></p>
                  <p><b>Father Name:</b> <%= s.fatherName || "N/A" %></p>
                  <p><b>Mother Name:</b> <%= s.motherName || "N/A" %></p>
                  <p><b>DOB:</b> <%= s.dob || "N/A" %></p>
                  <p><b>Gender:</b> <%= s.gender || "N/A" %></p>
                  <p><b>Aadhaar:</b> <%= s.aadhaar || "N/A" %></p>
                  <p><b>Phone:</b> <%= s.phone || "N/A" %></p>
                  <p><b>Email:</b> <%= s.email || "N/A" %></p>
                  <p><b>Category:</b> <%= s.caste || "N/A" %></p>
                  <p><b>Income:</b> ₹<%= s.income || "N/A" %></p>
                  <p><b>College:</b> <%= s.college || "N/A" %></p>
                  <p><b>Course:</b> <%= s.course || "N/A" %></p>
                  <p><b>Branch:</b> <%= s.branch || "N/A" %></p>
                  <p><b>Semester:</b> <%= s.semester || "N/A" %></p>
                  <p><b>Roll No:</b> <%= s.rollNo || "N/A" %></p>
                  <p><b>Registration No:</b> <%= s.registrationNo || "N/A" %></p>
                  <p><b>Bank:</b> <%= s.bankName || "N/A" %></p>
                  <p><b>Account No:</b> <%= s.accountNo || "N/A" %></p>
                  <p><b>IFSC:</b> <%= s.ifsc || "N/A" %></p>
                  <p><b>Status:</b> <%= s.status || "Pending" %></p>
                </div>
              </td>
            </tr>

          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="admin-box full-box">
    <div class="box-heading">
      <span>🗂️</span>
      <div>
        <h2>Manage Notices</h2>
        <p>Delete old or unnecessary notices.</p>
      </div>
    </div>

    <div class="admin-notice-grid">
      <% notices.forEach((n, i) => { %>
        <div class="admin-notice-card">
          <span class="notice-tag"><%= n.category || "Notice" %></span>
          <h3><%= n.title %></h3>
          <p><%= n.message %></p>
          <small><%= n.date %></small>

          <form action="/admin/notice/delete/<%= i %>" method="POST">
            <button class="danger">Delete Notice</button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>

</section>

<script>
function toggleDetails(id) {
  const row = document.getElementById("details-" + id);

  if (row) {
    row.classList.toggle("show-detail");
  }
}

function searchStudent() {
  const input = document.getElementById("studentSearch").value.toLowerCase().trim();
  const rows = document.querySelectorAll(".student-row");

  rows.forEach(row => {
    const name = row.dataset.name || "";
    const aadhaar = row.dataset.aadhaar || "";
    const registration = row.dataset.registration || "";
    const detailRow = row.nextElementSibling;

    if (name.includes(input) || aadhaar.includes(input) || registration.includes(input)) {
      row.style.display = "";

      if (detailRow && detailRow.classList.contains("student-detail-row")) {
        detailRow.style.display = "";
      }

    } else {
      row.style.display = "none";

      if (detailRow && detailRow.classList.contains("student-detail-row")) {
        detailRow.style.display = "none";
      }
    }
  });
}

function resetSearch() {
  const input = document.getElementById("studentSearch");
  input.value = "";

  document.querySelectorAll(".student-row").forEach(row => {
    row.style.display = "";

    const detailRow = row.nextElementSibling;

    if (detailRow && detailRow.classList.contains("student-detail-row")) {
      detailRow.classList.remove("show-detail");
      detailRow.style.display = "";
    }
  });
}
</script>

<%- include("partials/footer") %>

</body>
</html>